NUXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NUXT_PUBLIC_SUPABASE_KEY=your-publishable-key

# Public site URL (used for sitemap.xml and robots.txt)
NUXT_PUBLIC_SITE_URL=https://your-domain.com

# Google Maps Embed API key (Contact page map — enable "Maps Embed API" in Google Cloud Console)
NUXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key

# Optional — required for `npm run seed` (or run supabase/seed/catalog.sql in the SQL editor)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Contact form edge function secrets (set in Supabase Dashboard → Edge Functions → contact-form → Secrets)
# RESEND_API_KEY=re_xxxxxxxx
# CONTACT_TO_EMAIL=info@verve-group.com
# CONTACT_FROM_EMAIL=Verve Contact <notifications@yourdomain.com>
